<!-- ===========================================
     JAVASCRIPT: SLIDE PRESENTATION CONTROLLER
     =========================================== -->
<script>
/* -----------------------------------------------
   SlidePresentation
   Controls navigation, animations, progress bar,
   nav dots, keyboard and touch events.
----------------------------------------------- */
class SlidePresentation {
  constructor() {
    this.slides = Array.from(document.querySelectorAll('.slide'));
    this.total = this.slides.length;
    this.current = 0;
    this.isScrolling = false;
    this.scrollTimeout = null;

    this.progressBar = document.getElementById('progressBar');
    this.navDotsContainer = document.getElementById('navDots');

    this.buildNavDots();
    this.setupIntersectionObserver();
    this.setupKeyboard();
    this.setupTouch();
    this.setupWheel();
    this.updateProgress(0);
  }

  /* Build navigation dots */
  buildNavDots() {
    this.slides.forEach((_, i) => {
      const dot = document.createElement('button');
      dot.className = 'nav-dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('aria-label', `Ir para slide ${i + 1}`);
      dot.addEventListener('click', () => this.goTo(i));
      this.navDotsContainer.appendChild(dot);
    });
  }

  updateDots(index) {
    const dots = this.navDotsContainer.querySelectorAll('.nav-dot');
    dots.forEach((d, i) => d.classList.toggle('active', i === index));
  }

  /* Update progress bar */
  updateProgress(index) {
    const pct = this.total > 1 ? (index / (this.total - 1)) * 100 : 100;
    this.progressBar.style.width = pct + '%';
  }

  /* Intersection observer: add .visible when slide enters viewport */
  setupIntersectionObserver() {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          const idx = this.slides.indexOf(entry.target);
          if (idx !== -1) {
            this.current = idx;
            this.updateDots(idx);
            this.updateProgress(idx);
          }
        }
      });
    }, { threshold: 0.5 });

    this.slides.forEach(s => observer.observe(s));
  }

  /* Smooth scroll to slide by index */
  goTo(index) {
    if (index < 0 || index >= this.total) return;
    this.slides[index].scrollIntoView({ behavior: 'smooth' });
    this.current = index;
  }

  /* Keyboard navigation */
  setupKeyboard() {
    document.addEventListener('keydown', (e) => {
      switch(e.key) {
        case 'ArrowDown':
        case 'ArrowRight':
        case ' ':
        case 'PageDown':
          e.preventDefault();
          this.goTo(this.current + 1);
          break;
        case 'ArrowUp':
        case 'ArrowLeft':
        case 'PageUp':
          e.preventDefault();
          this.goTo(this.current - 1);
          break;
        case 'Home':
          e.preventDefault();
          this.goTo(0);
          break;
        case 'End':
          e.preventDefault();
          this.goTo(this.total - 1);
          break;
      }
    });
  }

  /* Touch / swipe navigation */
  setupTouch() {
    let startY = 0;
    let startX = 0;
    document.addEventListener('touchstart', (e) => {
      startY = e.touches[0].clientY;
      startX = e.touches[0].clientX;
    }, { passive: true });

    document.addEventListener('touchend', (e) => {
      const dy = startY - e.changedTouches[0].clientY;
      const dx = startX - e.changedTouches[0].clientX;
      const absY = Math.abs(dy); const absX = Math.abs(dx);
      if (absY > absX && absY > 40) {
        this.goTo(dy > 0 ? this.current + 1 : this.current - 1);
      }
    }, { passive: true });
  }

  /* Mouse wheel navigation (throttled) */
  setupWheel() {
    document.addEventListener('wheel', (e) => {
      if (this.isScrolling) return;
      this.isScrolling = true;
      this.goTo(e.deltaY > 0 ? this.current + 1 : this.current - 1);
      clearTimeout(this.scrollTimeout);
      this.scrollTimeout = setTimeout(() => { this.isScrolling = false; }, 900);
    }, { passive: true });
  }
}

/* Init on DOM ready */
document.addEventListener('DOMContentLoaded', () => {
  new SlidePresentation();
  // Trigger first slide immediately
  setTimeout(() => {
    const first = document.querySelector('.slide');
    if (first) first.classList.add('visible');
  }, 100);
});
</script>
